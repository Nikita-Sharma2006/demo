PORT=5000
NODE_ENV=development

# MongoDB is required. Encode special characters in the password before placing it in the URI.
# Example password: my@pass#123
# Encoded password: my%40pass%23123
# MONGO_URI=mongodb+srv://username:encodedPassword@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGO_URI=your_mongodb_atlas_uri_with_encoded_password
DNS_SERVERS=8.8.8.8,1.1.1.1

FRONTEND_URL=http://localhost:5173

JWT_SECRET=your_strong_jwt_secret_key
JWT_EXPIRES_IN=7d
OTP_EXPIRES_IN_MINUTES=10

# Cloudinary is optional at startup, but required for upload features.
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# SMTP is optional at startup. If missing, Render will still deploy,
# but OTP email endpoints will return 503 until SMTP is configured.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_digit_gmail_app_password_without_spaces
SMTP_FROM=Auth App <your_email@gmail.com>

# Render backend settings:
# Root Directory: backend
# Build Command: npm install
# Start Command: npm start
